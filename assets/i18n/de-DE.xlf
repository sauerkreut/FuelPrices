      <trans-unit id="label.city"><source>City</source><target>Stadt</target></trans-unit>
        <trans-unit id="placeholder.citySearch"><source>Search city…</source><target>Stadt suchen…</target></trans-unit>
      <trans-unit id="label.postalCode"><source>Postal code</source><target>Postleitzahl</target></trans-unit>
      <trans-unit id="label.language"><source>Language</source><target>Sprache</target></trans-unit>
